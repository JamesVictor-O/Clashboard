# Venice AI (OpenAI-compatible)
VENICE_API_KEY=
# Optional alias accepted by the server if VENICE_API_KEY is not set.
VENICE_ADMIN_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=deepseek-v4-flash
# Per-task model overrides. Defaults to VENICE_MODEL if blank.
# deepseek-v4-flash  — fast, current knowledge, credit-efficient (debate + decision)
# deepseek-v4-pro    — deeper reasoning for judging (one call per battle)
# gemini-3-5-flash   — highest-speed summarisation for research
VENICE_DECISION_MODEL=deepseek-v4-flash
VENICE_DEBATE_MODEL=gemma-4-uncensored
VENICE_JUDGE_MODEL=deepseek-v4-pro
VENICE_JUDGE_RETRY_MODEL=deepseek-v4-flash
VENICE_JUDGE_MAX_TOKENS=1400
VENICE_JUDGE_TIMEOUT_MS=60000
VENICE_RESEARCH_MODEL=gemini-3-5-flash
VENICE_TIMEOUT_MS=120000
VENICE_MAX_RETRIES=2
# Offline-only deterministic AI text/judge. Production/demo with real Venice credit must stay false.
ENABLE_VENICE_FALLBACK=false

# 1Shot Relayer / ERC-7710 delegated execution
ONESHOT_API_KEY=
ONESHOT_API_SECRET=
ONESHOT_BUSINESS_ID=
# Optional override. Defaults to public relayer mainnet/testnet URL by chain.
ONESHOT_RELAYER_URL=
NEXT_PUBLIC_ONESHOT_RELAYER_URL=
# 1Shot internal wallet UUID, not the wallet's 0x account address.
ONESHOT_WALLET_ID=
# Optional if using a DelegationManager contract. Per-agent executor auth uses ONESHOT_EXECUTOR_ADDRESS.
ONESHOT_DELEGATION_MANAGER=
# 1Shot server wallet/account address authorized by agents for delegated arena actions.
ONESHOT_EXECUTOR_ADDRESS=
NEXT_PUBLIC_ONESHOT_EXECUTOR_ADDRESS=
# Local demo only. Production should leave this false/unset.
ONESHOT_MOCK=false

# Base RPC endpoints
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=

# Smart contract addresses
NEXT_PUBLIC_ARENA_CONTRACT=0xb657eC98149a202277588819c4302d7Fe596F7ac
NEXT_PUBLIC_REGISTRY_CONTRACT=0xF96197F51E374fC6Ad361B30C5232AD4ed14c8fF
NEXT_PUBLIC_TREASURY_CONTRACT=0x2E48B58ADd4e995dD7F8EB3dDf3ccb9031c07e48
NEXT_PUBLIC_HOTTAKEROOMS_CONTRACT=0x888B974a4BdcfAF7586B13C511e26d8dBdaFbF70
NEXT_PUBLIC_EVENT_START_BLOCK=42464425
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Chain config
NEXT_PUBLIC_CHAIN_ID=84532

# Platform
PLATFORM_PRIVATE_KEY=
PLATFORM_TREASURY_ADDRESS=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional. If set, /api/battle/worker requires this as Bearer token or x-battle-worker-secret.
BATTLE_WORKER_SECRET=

# x402 research payments
# Set true when server-side agent research buyer permissions are wired.
X402_ENFORCE=false
# Defaults to ${NEXT_PUBLIC_APP_URL}/api/facilitator. Override only for external facilitator deployments.
X402_FACILITATOR_URL=
DATA_WALLET_ADDRESS=
# Custom Clashboard x402 facilitator. Buyers scope ERC-7710 redelegations to this address.
FACILITATOR_SIGNER_ADDRESS=
# Optional only if our facilitator must sign directly in a future 1Shot relayer flow.
FACILITATOR_PRIVATE_KEY=
# If true, /verify fails when relayer_estimate7710Transaction is unavailable.
X402_VERIFY_STRICT=false
# Local rail test only: enables /api/dev/research/seed.
ENABLE_X402_RAIL_TEST=false
# Optional hackathon/demo helper: preloads one fighter with sellable research so the
# other fighter can perform a real x402 -> 1Shot A2A purchase before Venice debates.
ENABLE_A2A_SEEDED_INVENTORY=false
NEXT_PUBLIC_ENABLE_A2A_SEEDED_INVENTORY=false
# Deprecated legacy switch. Keep false; use ENABLE_A2A_SEEDED_INVENTORY or ENABLE_VENICE_FALLBACK.
ENABLE_E2E_BATTLE_FALLBACK=false
