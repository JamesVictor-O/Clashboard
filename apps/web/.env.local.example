# Venice AI (OpenAI-compatible)
VENICE_API_KEY=

# 1Shot Relayer / ERC-7710 delegated execution
ONESHOT_API_KEY=
ONESHOT_API_SECRET=
ONESHOT_BUSINESS_ID=
# Optional override. Defaults to public relayer mainnet/testnet URL by chain.
ONESHOT_RELAYER_URL=
NEXT_PUBLIC_ONESHOT_RELAYER_URL=
# 1Shot internal wallet UUID, not the wallet's 0x account address.
ONESHOT_WALLET_ID=
# Optional if using a DelegationManager contract. Per-agent executor auth uses ONESHOT_EXECUTOR_ADDRESS.
ONESHOT_DELEGATION_MANAGER=
# 1Shot server wallet/account address authorized by agents for delegated arena actions.
ONESHOT_EXECUTOR_ADDRESS=
NEXT_PUBLIC_ONESHOT_EXECUTOR_ADDRESS=
# Local demo only. Production should leave this false/unset.
ONESHOT_MOCK=false

# Base RPC endpoints
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=

# Smart contract addresses
NEXT_PUBLIC_ARENA_CONTRACT=
NEXT_PUBLIC_REGISTRY_CONTRACT=
NEXT_PUBLIC_TREASURY_CONTRACT=
NEXT_PUBLIC_HOTTAKEROOMS_CONTRACT=
NEXT_PUBLIC_USDC_ADDRESS=

# Chain config
NEXT_PUBLIC_CHAIN_ID=84532

# Platform
PLATFORM_TREASURY_ADDRESS=
NEXT_PUBLIC_APP_URL=http://localhost:3000
